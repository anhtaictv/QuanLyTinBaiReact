PORT=5001
DB_USER=
DB_PASSWORD=
DB_SERVER=localhost
DB_NAME=QuanLyTinBai
JWT_SECRET=

# Local folder for uploaded files
STORAGE_ROOT=./uploads

# Google Drive integration (optional) - OAuth2, token stored in google-token.json
# (see getToken.js). service-account.json is NOT used by the app.
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Web Push / VAPID (optional) - generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@example.com

# Telegram alert khi có lỗi server (optional) - tạo bot qua @BotFather, lấy chat_id
# bằng cách nhắn bot rồi mở https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Backup database tự động (optional) - dùng bởi scripts/daily-backup.js
DB_BACKUP_DIR=C:\WebApp\db_backups
DB_BACKUP_RETENTION_DAYS=14

# Gửi email "Quên mật khẩu" qua Gmail (optional, cần đủ cả 3 biến mới hoạt động).
# GMAIL_APP_PASSWORD tạo tại https://myaccount.google.com/apppasswords (cần bật
# 2-Step Verification trước) - KHÔNG dùng mật khẩu Gmail thường.
# FRONTEND_URL là domain public của SPA, dùng để build link trong email.
GMAIL_USER=
GMAIL_APP_PASSWORD=
FRONTEND_URL=https://qltb.work.gd
